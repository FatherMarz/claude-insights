{
  "name": "claude-insights",
  "version": "0.1.0",
  "description": "Local meta-monitoring dashboard for Claude Code — reads ~/.claude/projects JSONL and visualizes operations, quality drift, activity, and Max-plan usage.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "claude-code",
    "anthropic",
    "dashboard",
    "monitoring",
    "observability"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm run server\" \"vite\"",
    "server": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.10",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vite": "^7.2.2"
  }
}
